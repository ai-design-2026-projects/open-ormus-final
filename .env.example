# ── Database (Supabase) ────────────────────────────────────────────────────────
# DATABASE_URL  — pooled (Transaction mode, port 6543) — runtime queries
#                 Settings → Database → Connection pooling → Transaction mode
# DIRECT_URL    — direct (no pooler, port 5432) — Prisma migrate DDL only
#                 Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Find these on: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ── Site ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── External APIs ──────────────────────────────────────────────────────────────
EXA_API_KEY=your_exa_api_key_here

# ── MCP Server ─────────────────────────────────────────────────────────────────
MCP_PORT=3001
MCP_SERVER_URL=http://localhost:3001/mcp
# Set to "true" for local dev to skip JWT validation. Remove in production.
MCP_AUTH_DISABLED=false
# Required when MCP_AUTH_DISABLED=false. Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ── LLM proxy (frontend → LiteLLM) ────────────────────────────────────────────
# Start LiteLLM with: bun run dev:llm
ANTHROPIC_BASE_URL="http://localhost:4000"
ANTHROPIC_API_KEY="any-string"
# Must match a model_name in litellm_config.yaml
CONVERSATION_MODEL="default"

# ── LiteLLM provider credentials ──────────────────────────────────────────────
# LITELLM_MODEL and LITELLM_API_KEY live in litellm.env.local (not here).
# Copy litellm.env.example → litellm.env.local and fill in your provider key.
