# Database (Supabase)
# Find this on: supabase.com → project → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# MCP Server
PORT=3001

# Set to "true" for local dev — skips JWT validation.
# Remove in production.
MCP_AUTH_DISABLED=true

# Required when MCP_AUTH_DISABLED is unset.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
