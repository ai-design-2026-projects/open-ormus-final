# Database (Supabase)
# Find this on: supabase.com → project → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Supabase Auth
# Find these on: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Site URL (used in auth email links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# MCP Server
PORT=3001

# Set to "true" for local dev — skips JWT validation.
# Remove in production.
MCP_AUTH_DISABLED=true

# Required when MCP_AUTH_DISABLED is unset.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Exa Search API
# Get this from: https://dashboard.exa.ai/
EXA_API_KEY=your_exa_api_key_here

# LiteLLM proxy (Anthropic-compatible API)
# Start with: bun run dev:llm
ANTHROPIC_BASE_URL="http://localhost:4000"
ANTHROPIC_API_KEY="any-string"  # LiteLLM local dev doesn't require a real key here

# Alias sent by the frontend — must match model_name in litellm_config.yaml
CONVERSATION_MODEL="default"

# LiteLLM config — read by litellm_config.yaml via os.environ/
# Change these to switch provider without touching the yaml
LITELLM_MODEL="gemini/gemini-2.5-flash-lite"   # any LiteLLM-supported model string
LITELLM_API_KEY="your-provider-api-key"
