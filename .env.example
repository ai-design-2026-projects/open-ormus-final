# Database (Supabase)
# Find this on: supabase.com → project → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Supabase Auth
# Find these on: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Site URL (used in auth email links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# MCP Server
PORT=3001

# Set to "true" for local dev — skips JWT validation.
# Remove in production.
MCP_AUTH_DISABLED=true

# Required when MCP_AUTH_DISABLED is unset.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Exa Search API
# Get this from: https://dashboard.exa.ai/
EXA_API_KEY=your_exa_api_key_here
