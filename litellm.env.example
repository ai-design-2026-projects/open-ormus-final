# LiteLLM proxy — provider credentials
# Copy to litellm.env.local and fill in your values.
# This file is intentionally separate from .env.local so that the LiteLLM
# process never sees DATABASE_URL or other app secrets.

# Any LiteLLM-supported model string, e.g.:
#   openrouter/minimax/minimax-m2.7
#   gemini/gemini-2.5-flash-lite
#   anthropic/claude-haiku-4-5-20251001
LITELLM_MODEL="gemini/gemini-2.5-flash-lite"

# Provider API key for the model above
LITELLM_API_KEY="your-provider-api-key"
