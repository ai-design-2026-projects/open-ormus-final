generator client {
  provider = "prisma-client"
  output   = "../frontend/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

